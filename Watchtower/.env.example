# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key for Claude AI report generation
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Secret key for signing session cookies — use a long random string (64+ chars)
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Cloudflare Turnstile secret key for bot protection on the citizen form
# Get yours at https://dash.cloudflare.com → Turnstile
# If left blank, Turnstile verification is skipped (not recommended in production)
TURNSTILE_SECRET_KEY=
